# MongoDB
# Use a Salvia-specific database user. It must be unable to write to
# Rosmarinus-owned collections.
MONGODB_URI=mongodb://salvia:replace-with-password@localhost:27017/salvia?authSource=salvia
MONGODB_DATABASE=salvia

# WebAuthn / passkeys
# RP ID is a hostname without a scheme or port. Origins are full origins with
# no trailing slash; separate multiple allowed origins with commas.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Salvia
WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3000

# Salvia sessions
# Generate at least 32 random bytes and encode them as base64url. Never reuse
# an Ably API key or another service secret here.
SESSION_SECRET=replace-with-at-least-32-random-bytes-as-base64url
SESSION_COOKIE_NAME=salvia_session
SESSION_TTL=30d

# Ably browser credentials and account authorization control
# These are server-only API keys with separate, narrowly scoped capabilities.
ABLY_BROWSER_TOKEN_API_KEY=replace-with-browser-token-api-key
ABLY_CONTROL_API_KEY=replace-with-account-control-api-key
ABLY_TOKEN_TTL=15m

# Rosmarinus integration contract
ABLY_COMMAND_CHANNEL=rosmarinus:commands
ABLY_ACCOUNT_EVENT_NAMESPACE=rosmarinus:accounts
ABLY_ACCOUNT_CONTROL_CHANNEL=rosmarinus:control:accounts
